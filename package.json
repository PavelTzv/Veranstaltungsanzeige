{
  "name": "veranstaltungsanzeige",
  "version": "1.1.1",
  "description": "Software zum automatischen und täglichen Anzeigen von Veranstaltungen.",
  "license": "Apache-2.0",
  "author": "Pavel Tzvetkov",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^39.0.0",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.paveltzvetkov.veranstaltungsanzeige",
    "productName": "Veranstaltungsanzeige",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "source/build-icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": true
    },
    "publish": [
      {
        "provider": "github"
      }
    ]
  }
}
